# To prevent access to .env and other files
<Files .*>
# Apache 2.2
<IfModule !mod_authz_core.c>
Order deny,allow
Deny from all
</IfModule>
# Apache 2.4
<IfModule mod_authz_core.c>
Require all denied
</IfModule>
</Files>

<IfModule mod_rewrite.c>
RewriteEngine On

# Force opening URL to /index.php
RewriteRule ^$ /index.php [R=302,L]

# If domain document root points to project root instead of /public,
# internally route requests into /public.
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^(.*)$ public/$1 [L]
</IfModule>